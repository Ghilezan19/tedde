# ============================================
# Tedde Unified Camera Service - Python only
# ============================================
# Copiaza fisierul: cp .env_example .env
# Completeaza valorile reale in .env (nu il urca pe git).

# ---- FastAPI server ----
PY_SERVER_PORT=8000

# ---- Output directories ----
SNAPSHOT_DIR=./snapshots
RECORDINGS_DIR=./recordings
EVENTS_DIR=./events

# ---- ffmpeg ----
# Daca nu este setat, ajusteaza manual calea pentru sistemul tau.
FFMPEG_PATH=/opt/homebrew/bin/ffmpeg

# ============================================
# Camera 1 - fixa (HiLook)
# ============================================
CAMERA_IP=192.168.1.100
CAMERA_USERNAME=admin
CAMERA_PASSWORD=parola_camera_1
CAMERA_RTSP_PORT=554
RTSP_MAIN_PATH=/Streaming/channels/101
RTSP_SUB_PATH=/Streaming/channels/102

# ============================================
# Camera 2 - PTZ (HiLook PTZ-N2C400I-W)
# ============================================
CAMERA2_IP=192.168.1.101
CAMERA2_USERNAME=admin
CAMERA2_PASSWORD=parola_camera_2
CAMERA2_RTSP_PORT=554
CAMERA2_HTTP_PORT=80
CAMERA2_SDK_PORT=8000
RTSP2_MAIN_PATH=/Streaming/channels/101
RTSP2_SUB_PATH=/Streaming/channels/102

# ---- Workflow / ESP ----
RECORDING_DURATION_SECONDS=60
# Optional: countdown shown on ESP; if missing, backend returns
# RECORDING_DURATION_SECONDS in GET /api/esp/config.
# ESP_COUNTDOWN_SECONDS=60
WORKFLOW_RECORD_STREAM=main

# ---- ALPR ----
ALPR_ENABLED=1
ALPR_CAMERA=1
# Prag detectie YOLO (0.05–0.95). Libraria fast-alpr foloseste implicit 0.4; valori mai mici
# ajuta placute mici/departe (ex. 0.12–0.22). Ridica daca apar false positive.
ALPR_DETECTOR_CONF_THRESH=0.1
# 1 = detector ONNX doar pe CPU (recomandat pe macOS dacă nu apare nicio detecție). 0 = provideri default (GPU/CoreML).
ALPR_DETECTOR_CPU_ONLY=1
# 1 = dacă prima trecere ALPR nu găsește plăcuță, reîncearcă pe imagine mărită în RAM (ajută la cadre mari / plăcuță mică).
ALPR_UPSCALE_RETRY=1
ALPR_PREDICT_UPSCALE=1.5

# ---- Camera 2 audio / IR behavior ----
AUTO_DAY_MODE_ON_START=1
TTS_ENABLED=0
TTS_LANGUAGE=ro
TTS_START_MESSAGE=Inregistrarea a inceput
TTS_END_MESSAGE=Inregistrarea s-a finalizat cu succes
TTS_VOLUME=100

# ---- PTZ presets (future workflow extensions) ----
PTZ_PRESET_HOME=1
PTZ_PRESET_SECONDARY=2
PTZ_SETTLE_SECONDS=3
PTZ_SECONDARY_RECORDING_SECONDS=120
PTZ_HOME_RECORDING_SECONDS=60
