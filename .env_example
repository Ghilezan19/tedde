# ============================================
# Tedde Unified Camera Service - Python only
# ============================================
# Copiaza fisierul: cp .env_example .env
# Completeaza valorile reale in .env (nu il urca pe git).

# ---- First configuration (wizard) ----
# După ce ai setat IP-urile și parolele RTSP, rulează din rădăcina repo-ului:
#   ./orchestrate.sh first-configuration   (sau ./lib/orchestrate.sh first-configuration)
# Face: health (ffmpeg, TCP camere, directoare), snapshot, benchmark toți detectorii
# ALPR, alegere interactivă a lui ALPR_DETECTOR_MODEL, apoi pre-teste HTTP dacă serverul rulează.
#
# Completează .env cu chei noi din acest exemplu (fără a șterge valorile tale):
#   ./orchestrate.sh sync-env [--dry-run]
# Health lizibil în terminal:
#   ./orchestrate.sh health

# ---- FastAPI server ----
PY_SERVER_PORT=8000

# ---- Output directories ----
SNAPSHOT_DIR=./snapshots
RECORDINGS_DIR=./recordings
EVENTS_DIR=./events

# ---- ffmpeg ----
# Daca nu este setat, ajusteaza manual calea pentru sistemul tau.
FFMPEG_PATH=/opt/homebrew/bin/ffmpeg

# ============================================
# Camera 1 - fixa (HiLook)
# ============================================
CAMERA_IP=192.168.1.100
CAMERA_USERNAME=admin
CAMERA_PASSWORD=parola_camera_1
CAMERA_RTSP_PORT=554
# HTTP ISAPI (TwoWayAudio / live talk) pentru camera 1 — folosit când AUDIO_ISAPI_CAMERA=1
CAMERA1_HTTP_PORT=80
RTSP_MAIN_PATH=/Streaming/channels/101
RTSP_SUB_PATH=/Streaming/channels/102

# ============================================
# Camera 2 - PTZ (HiLook PTZ-N2C400I-W)
# ============================================
CAMERA2_IP=192.168.1.101
CAMERA2_USERNAME=admin
CAMERA2_PASSWORD=parola_camera_2
CAMERA2_RTSP_PORT=554
CAMERA2_HTTP_PORT=80
CAMERA2_SDK_PORT=8000
RTSP2_MAIN_PATH=/Streaming/channels/101
RTSP2_SUB_PATH=/Streaming/channels/102
# Profil ONVIF folosit de clientul PTZ (Camera 2).
CAMERA2_ONVIF_PROFILE=Profile_1

# ---- Workflow / ESP ----
RECORDING_DURATION_SECONDS=60
# Optional: countdown shown on ESP; if missing, backend returns
# RECORDING_DURATION_SECONDS in GET /api/esp/config.
# ESP_COUNTDOWN_SECONDS=60
WORKFLOW_RECORD_STREAM=main
# Camera folosită implicit la înregistrarea declanșată de ESP (1=fixă, 2=PTZ).
DEFAULT_RECORDING_CAMERA=2
# Opțional: notezi aici IP-ul ESP după ce îl vezi în Serial / DHCP — apare pe GET /help-esp1
# ESP_DEVICE_IP=192.168.1.50
# ESP_HELP_NOTE=ESP birou / locație 1

# ---- ALPR ----
ALPR_ENABLED=1
# Snapshot workflow + /api/alpr/test: întotdeauna camera 2 (față / PTZ). ALPR_CAMERA din .env este ignorat.
# Prag detectie YOLO (0.05–0.95). Libraria fast-alpr foloseste implicit 0.4; valori mai mici
# ajuta placute mici/departe (ex. 0.12–0.22). Ridica daca apar false positive.
ALPR_DETECTOR_CONF_THRESH=0.1
# 1 = detector ONNX doar pe CPU (recomandat pe macOS dacă nu apare nicio detecție). 0 = provideri default (GPU/CoreML).
ALPR_DETECTOR_CPU_ONLY=1
# 1 = dacă prima trecere ALPR nu găsește plăcuță, reîncearcă pe imagine mărită în RAM (ajută la cadre mari / plăcuță mică).
ALPR_UPSCALE_RETRY=1
ALPR_PREDICT_UPSCALE=1.5
# Detector ONNX (open-image-models). Ex. yolo-v9-s-608-license-plate-end2end pentru rezoluție mai mare.
ALPR_DETECTOR_MODEL=yolo-v9-t-384-license-plate-end2end
# OCR (fast-plate-ocr). Ex. european-plates-mobile-vit-v2-model pentru plăci EU.
ALPR_OCR_MODEL=cct-xs-v2-global-model

# ---- Camera 2 audio / IR behavior ----
# Care cameră primește ISAPI TwoWayAudio (Vorbește / TTS): 1=fixă, 2=PTZ (implicit).
# Interfața web nu schimbă ținta după tab-ul video; opțional API: POST /api/audio/open?camera=1|2.
# Dacă PTZ returnează 404 la /api/audio/open, încearcă 1 dacă IPC-ul fix suportă difuzor ISAPI.
AUDIO_ISAPI_CAMERA=2
AUTO_DAY_MODE_ON_START=1
TTS_ENABLED=0
TTS_LANGUAGE=ro
TTS_START_MESSAGE=Inregistrarea a inceput
TTS_END_MESSAGE=Inregistrarea s-a finalizat cu succes
TTS_VOLUME=100
# La 502 la POST /api/audio/open: vezi câmpul JSON `detail` și logurile serverului
#   grep '[AUDIO]' logs/uvicorn.log
# Verificare fără UI: PYTHONPATH=py_backend python -m tools.probe_twoway_audio

# ---- PTZ presets (future workflow extensions) ----
PTZ_PRESET_HOME=1
PTZ_PRESET_SECONDARY=2
PTZ_SETTLE_SECONDS=3
PTZ_SECONDARY_RECORDING_SECONDS=120
PTZ_HOME_RECORDING_SECONDS=60

# ---- Customer portal / SMS ----
PUBLIC_BASE_URL=http://localhost:8000
PORTAL_PATH_PREFIX=/verificare
CUSTOMER_PORTAL_DB_PATH=./data/customer_portal.sqlite3
CUSTOMER_LINK_TTL_DAYS=30
SMS_BACKEND=mock
SMS_HTTP_URL=
SMS_HTTP_METHOD=POST
SMS_HTTP_HEADERS_JSON={}
SMS_HTTP_BODY_TEMPLATE=
PORTAL_BRAND_NAME=TEDDE AUTO
PORTAL_FOOTER_PHONE=0744 658 650
PORTAL_FOOTER_EMAIL=office@tedde-auto.ro
PORTAL_FOOTER_ADDRESS=Satchinez, str. Daliei, nr. 27, jud. Timis
PORTAL_FOOTER_HOURS=Luni - Vineri: 08:30 - 17:00 / Sambata: 08:30 - 13:00 / Duminica: Inchis
PORTAL_THEME_ACCENT=#59c7e8
PORTAL_THEME_DARK=#2f2f2f
# Logo portal client (fișier sub public/); default dacă omis: /public/logo.png
PORTAL_LOGO_URL=/public/logo.png

# ---- Admin dashboards auth ----
# Parola pentru /admin (rol: admin)
ADMIN_PASSWORD=admin
# Parola pentru /super-admin (rol: superadmin)
SUPERADMIN_PASSWORD=DentaTimis02
# Secret key pentru semnarea cookie-urilor de sesiune (schimbă în producție!)
SESSION_SECRET_KEY=change-me-in-production-use-a-random-secret

# ---- RFC (design only) ----
# ALPR pe video încărcat: vezi lib/ALPR_VIDEO_RFC.md (nu e încă în API).
